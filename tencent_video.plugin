#!name=腾讯视频去广告（增强版）
#!desc=开屏+播放前广告+推荐流+试看限制
#!author=ChatGPT优化版

[Rewrite]
# 开屏 & 广告资源拦截
^https?:\/\/.*\.qq\.com\/.*(splash|advert|ad|startup|launch|commercial).* url reject-dict

# 视频广告接口
^https?:\/\/vv\.video\.qq\.com\/getad reject-dict
^https?:\/\/vd\.video\.qq\.com\/.*ad.* reject-dict

# 去除试看限制（关键）
^https?:\/\/vv\.video\.qq\.com\/getvinfo url script-response-body https://raw.githubusercontent.com/Lemu-ux/loon-plugins/main/tencent_video.js

[Script]
# 首页数据清洗
http-response ^https?:\/\/pbaccess\.video\.qq\.com\/.* requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/Lemu-ux/loon-plugins/main/tencent_video.js,tag=腾讯视频去广告

# 播放页数据清洗
http-response ^https?:\/\/vv\.video\.qq\.com\/.* requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/Lemu-ux/loon-plugins/main/tencent_video.js,tag=腾讯视频去广告

[MITM]
hostname = %APPEND% vv.video.qq.com, pbaccess.video.qq.com, vd.video.qq.com