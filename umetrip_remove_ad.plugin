#!name=航旅纵横去开屏广告（简化版）
#!desc=仅去除航旅纵横的开屏广告
#!author=ChatGPT

[Rewrite]
^https?:\/\/([^\/]+\.)?(umetrip|flightmanager|hxtrip)\.(com|cn)\/.*(splash|startup|launch).* url reject-dict

[Script]
http-response ^https?:\/\/([^\/]+\.)?(umetrip|flightmanager|hxtrip)\.(com|cn)\/.* requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/Lemu-ux/loon-plugins/main/umetrip_remove_ad.js,tag=航旅纵横去开屏广告

[MITM]
hostname = %APPEND% *.umetrip.com, *.flightmanager.com, *.hxtrip.com
